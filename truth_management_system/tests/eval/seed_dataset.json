    {"key": "wife_anna", "statement": "My wife's name is Anna", "claim_type": "fact", "context_domain": "relationships"},
    {"key": "friend_sara_doctor", "statement": "My friend Sara is a doctor", "claim_type": "fact", "context_domain": "relationships"},
