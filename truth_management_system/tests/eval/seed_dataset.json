{
  "name": "pkb_seed_v3",
  "description": "Persona retrieval eval set with lifecycle-bearing claims and hard cases. Categories: lexical (FTS should win), semantic (paraphrase, no shared word-prefix — needs embeddings), multi (several targets), temporal (two dated claims on a topic, recall both), recency (expect the NEWER only — ordering signal, needs Workstream C), conflict (contradictory active claims, expect the current one — needs conflict/supersession D/H), hard_negative (a tempting distractor shares strong tokens — ranking/precision signal), scoped (per-case SearchFilters — existing capability), lifecycle (superseded/expired must be excluded — existing status+expiry). Relative timestamps like '-400d' resolve to now-delta at seed time; a past valid_to + the runner's expiry sweep marks a claim 'expired'. Semantic/recency/conflict cases are expected to score LOW under network-free FTS — that headroom is the point. Replace/augment with real anonymized queries over time (plan Workstream G).",
  "claims": [
    {"key": "gym_morning", "statement": "I go to the gym every morning at 6am", "claim_type": "habit", "context_domain": "health"},
    {"key": "vegetarian", "statement": "I am a vegetarian and do not eat meat", "claim_type": "fact", "context_domain": "health", "created_at": "-250d", "updated_at": "-250d"},
    {"key": "peanut_allergy", "statement": "I am allergic to peanuts", "claim_type": "fact", "context_domain": "health"},
    {"key": "knee_injury", "statement": "I injured my left knee while skiing in 2019", "claim_type": "memory", "context_domain": "health"},
