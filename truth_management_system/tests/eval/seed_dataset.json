    {"query": "planning Japan spring", "expected": ["trip_japan"], "category": "lexical"},
    {"query": "visited Paris", "expected": ["visited_paris"], "category": "lexical"},
    {"query": "piano lessons January", "expected": ["piano_lessons"], "category": "lexical"},
