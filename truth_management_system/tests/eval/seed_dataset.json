    {"query": "promoted team lead", "expected": ["promoted_lead"], "category": "lexical"},

    {"query": "food restrictions and dietary needs", "expected": ["vegetarian"], "category": "semantic", "notes": "no shared word-prefix with 'vegetarian / eat meat'"},
    {"query": "current employer and occupation", "expected": ["job_acme"], "category": "semantic"},
    {"query": "fear of airplanes and flights", "expected": ["hate_flying"], "category": "semantic"},
    {"query": "days I avoid the office", "expected": ["remote_tuesdays"], "category": "semantic"},
    {"query": "literature genres I prefer", "expected": ["read_scifi"], "category": "semantic"},
    {"query": "who did I marry", "expected": ["wife_anna"], "category": "semantic"},
    {"query": "sport played by the kids", "expected": ["son_soccer"], "category": "semantic"},
    {"query": "putting money aside for the future", "expected": ["save_retirement"], "category": "semantic"},
    {"query": "preferred type of cuisine", "expected": ["love_sushi"], "category": "semantic"},
    {"query": "any chronic medical conditions", "expected": ["peanut_allergy"], "category": "semantic"},

    {"query": "morning", "expected": ["gym_morning", "early_riser"], "category": "multi"},
    {"query": "loan", "expected": ["car_loan", "student_loan"], "category": "multi"},

    {"query": "diet", "expected": ["diet_old", "diet_new"], "category": "temporal", "notes": "recall both dated diet claims; the 'recency' case tests which one ranks first"},

    {"query": "iphone", "expected": ["phone_new"], "not_expected": ["phone_old"], "category": "recency", "notes": "distinctive query isolates the pair; newer should outrank older once recency ranking lands (Workstream C)"},
    {"query": "honda tesla", "expected": ["car_new"], "not_expected": ["car_old"], "category": "recency", "notes": "Honda (old) vs Tesla (new) — distinctive, isolates the pair"},
    {"query": "keto mediterranean", "expected": ["diet_new"], "not_expected": ["diet_old"], "category": "recency", "notes": "keto (old) vs Mediterranean (new) — distinctive, isolates the pair"},

    {"query": "eat meat", "expected": ["eat_chicken"], "not_expected": ["vegetarian"], "category": "conflict", "notes": "contradictory claims; the current (eat_chicken, recent) should beat the stale belief (vegetarian, old) once recency/supersession lands (Workstream C/D/H)"},

    {"query": "car loan", "expected": ["car_loan"], "not_expected": ["car_old", "car_new"], "category": "hard_negative", "notes": "'car' distractors compete with the finance claim"},
    {"query": "March plans", "expected": ["march_offsite"], "not_expected": ["mom_birthday"], "category": "hard_negative", "notes": "birthday shares 'March'"},

    {"query": "deadline", "expected": ["project_deadline"], "category": "scoped", "filters": {"claim_types": ["task"]}, "notes": "type-scoped search"},
    {"query": "appointment", "expected": ["dentist_appt"], "category": "scoped", "filters": {"context_domains": ["life_ops"]}, "notes": "domain-scoped search"},

    {"query": "where do I work now", "expected": ["job_acme"], "not_expected": ["job_globex"], "category": "lifecycle", "notes": "superseded job_globex must be excluded by default status filter"},
    {"query": "gym membership", "expected": ["gym_morning"], "not_expected": ["gym_trial"], "category": "lifecycle", "notes": "expired gym_trial (past valid_to) must be excluded after the expiry sweep"}
